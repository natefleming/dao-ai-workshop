# Copy to .env and adjust for your workspace. Default values shown are
# "known-good on aws-field-eng" - they work out of the box for the
# workshop author and give an engineer a runnable default path.
# Override per-student or per-workspace as needed.

# =============================================================================
# Databricks auth
# =============================================================================

# Databricks CLI profile (matches ~/.databrickscfg). Used by local tools
# (databricks-sdk, bundle deploy). Workspace notebooks infer identity
# from the notebook context, so this is for local work only.
DATABRICKS_CONFIG_PROFILE=aws-field-eng


# =============================================================================
# Workshop catalog / schema
# =============================================================================

# Catalog name for all workshop assets. Leave blank to auto-derive
# "workshop_<your_username>" at runtime (per-student isolation). Override
# to a shared catalog if your org locks down catalog creation.
DAO_AI_WORKSHOP_CATALOG=


# =============================================================================
# Chapter 3 - Genie
# =============================================================================
# Create a Genie Space in the UI (SQL Editor > Genie > New Genie Space)
# and copy the space id from the URL. The defaults below are Nate's
# Merchandising Analytics and Sales and Pricing spaces on aws-field-eng,
# reused from the sporting_goods_store dao-ai example - safe to use for
# testing but not for production.

GENIE_SPACE_ID=01f124c2646f1ed4846cae3f8b36df02
GENIE_SPACE_ID_SALES=01f124c2690f1dcb93a15057c2a74339


# =============================================================================
# Chapter 4 - MCP
# =============================================================================
# Managed MCP servers infer auth from the notebook's WorkspaceClient -
# no credentials needed here for the primary example. Only set these
# if you want to run MCP against a workspace other than the one your
# notebook is attached to (advanced; rare).

# DAO_AI_WORKSHOP_HOST=https://e2-demo-field-eng.cloud.databricks.com


# =============================================================================
# Chapter 5 - REST
# =============================================================================
# Optional bearer token for the external REST API example. The default
# chapter hits a public, auth-free API so this is unset by default.

# DAO_AI_WORKSHOP_API_TOKEN=


# =============================================================================
# Chapter 6 - Vector Search
# =============================================================================
# Vector Search endpoint name. The notebook uses this name; if the
# endpoint doesn't exist, create a STANDARD-tier endpoint in the
# Vector Search UI. Reuse an existing endpoint if your workspace has one.

DAO_AI_WORKSHOP_VS_ENDPOINT=dao_ai_workshop_vs


# =============================================================================
# Chapter 7 - Lakebase memory
# =============================================================================
# Lakebase (managed Postgres) for persistent conversation memory. The
# defaults below point at the retail-consumer-goods Lakebase instance
# on aws-field-eng (same one the sporting_goods_store dao-ai example
# uses). Create your own Lakebase instance in the UI for production.

LAKEBASE_NAME=retail-consumer-goods
LAKEBASE_PROJECT=retail-consumer-goods

# Optional service-principal creds for Lakebase OAuth. If unset, the
# notebook falls back to the calling user's identity. Only populate
# these if you need service-principal auth for a deployed app.

# RETAIL_AI_DATABRICKS_CLIENT_ID=
# RETAIL_AI_DATABRICKS_CLIENT_SECRET=
